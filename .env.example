# Required
OPENAI_API_KEY=sk-...

# OpenAI Realtime model (GA, post-2025).
# Cheap default: "gpt-realtime-mini". Top quality: "gpt-realtime" / "gpt-realtime-2".
OPENAI_REALTIME_MODEL=gpt-realtime-mini

# Voice (feminine: "shimmer", "sage", "coral", "alloy"). "shimmer" is warm & natural.
OPENAI_VOICE=shimmer

# Default language for the assistant's persona. Supported: it, en, es, fr, de.
# The browser can override this per session via the language dropdown.
ASSISTANT_LANGUAGE=it

# Vision worker: how often to caption the webcam frame (seconds).
VISION_CAPTION_INTERVAL=4.0

# Vision model id (HF). Moondream2 is small and runs on Mac MPS.
VISION_MODEL_ID=vikhyatk/moondream2

# Set to "cpu", "mps" (Apple Silicon) or "cuda".
VISION_DEVICE=mps

# Set to "false" to disable the vision worker entirely (audio-only mode).
VISION_ENABLED=true

# World model (V-JEPA 2 stub) — keep false unless you've wired the real model.
WORLD_MODEL_ENABLED=false

# Server. HOST=0.0.0.0 makes the server reachable from other devices on the
# same Wi-Fi (e.g. your phone at http://<mac-lan-ip>:8765). Use 127.0.0.1 to
# restrict to localhost only. Mic and webcam from a phone require HTTPS —
# see the "Accessing from another device" section in the README.
HOST=0.0.0.0
PORT=8765

# Soft daily spend reminder (USD). Just informational, no hard cutoff.
DAILY_BUDGET_USD=2.0

# Persistent memory across sessions.
# At session end, a cheap chat-API call (memory_summarizer_model) writes a 1-3
# sentence summary + key facts to MEMORY_PATH. At session start, the last
# MEMORY_RECALL_COUNT entries are injected as additional system context.
MEMORY_ENABLED=true
MEMORY_PATH=data/memory.jsonl
MEMORY_RECALL_COUNT=5
MEMORY_SUMMARIZER_MODEL=gpt-4o-mini

# Visual memory track. When true (and VISION_ENABLED is also true), the
# webcam scene captions produced during a session are summarized into a
# short "what Samantha saw" block at session-end and replayed as part of
# the recall context in the next session. Set to false to keep only the
# textual memory track.
VISUAL_MEMORY_ENABLED=true

# Agentic computer control (macOS only).
# When true, Samantha can call tools to open apps, open URLs, take
# screenshots, run Shortcuts, etc. First call to each capability may
# trigger a macOS permission prompt (Apple Events / Screen Recording).
AGENTIC_ENABLED=true

# Accessibility mode (opt-in via voice — "attiva modalità accessibilità").
# When on, the screen is OCR'd via Apple Vision every N seconds and the text
# is injected as context, so Samantha can read it to a visually impaired user
# without being verbose. Default mode is the standard one (off).
ACCESSIBILITY_SCREEN_INTERVAL=6.0

# Persistent user preferences. Tracks the accessibility flag (and any future
# knobs) so the next session starts in the same mode the user left it.
# To "forget" the persisted state, just delete this file.
PREFERENCES_PATH=data/preferences.json

# ── Cowork + knowledge wiki (Anthropic / Claude) ──────────────────────────
# Samantha can delegate open-ended knowledge-work to Claude (the engine behind
# Claude Cowork) and author new Agent Skills that Cowork and Claude Code pick
# up from COWORK_SKILLS_PATH. Provide ONE credential — a pay-per-use API key,
# or a Claude Pro/Max subscription OAuth token (sk-ant-oat..., from
# `ant auth login` / Claude Code). Leave both blank to keep Cowork dormant.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=claude-opus-4-8
COWORK_ENABLED=true
# Global dir read by Claude Cowork and Claude Code. "~" is expanded.
COWORK_SKILLS_PATH=~/.claude/skills

# Knowledge-base LLM wiki (Karpathy pattern): a persistent, interlinked
# markdown wiki Claude maintains (ingest / query / lint). Powered by the same
# Anthropic credential above.
WIKI_ENABLED=true
WIKI_PATH=data/wiki
# Max existing wiki pages loaded into the model's context per ingest/query.
WIKI_MAX_CONTEXT_PAGES=12

# File uploads (📎 in the UI): a dropped file (pdf/md/txt/docx/jpg/png) is read
# by Claude Opus and either filed into the wiki (kept under UPLOADS_PATH) or
# read once and deleted. UPLOAD_MAX_MB stays below Anthropic's 32 MB limit.
UPLOADS_PATH=data/uploads
UPLOAD_MAX_MB=25

# ── Time-based autonomy (Schedule + Pulse) ────────────────────────────────
# Both run only while a session is active. Manage them from the UI text bar
# with the /schedule and /pulse slash commands.
#
# Schedule: user-defined tasks fired at fixed times (standard 5-field cron).
# The store is polled every SCHEDULE_POLL_INTERVAL seconds (keep it < 60 so
# minute-granular cron never slips).
SCHEDULE_ENABLED=true
SCHEDULE_PATH=data/schedule.json
SCHEDULE_POLL_INTERVAL=20
# Pulse: ambient periodic check-in where Samantha decides whether to speak.
# The live on/off + interval are stored per-user in data/preferences.json
# (toggled via /pulse); this is just the default cadence in seconds.
PULSE_DEFAULT_INTERVAL_S=180
